# ========================================
# マリナ SNS自動投稿ツール - APIキー設定
# このファイルを .env にコピーして使用してください
# .env は絶対にGitHubにアップしないでください
# ========================================

# Claude API（Anthropic）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx

# X (Twitter) API
X_API_KEY=xxxxxxxxxx
X_API_SECRET=xxxxxxxxxx
X_ACCESS_TOKEN=xxxxxxxxxx
X_ACCESS_SECRET=xxxxxxxxxx

# Threads API（後で追加）
THREADS_ACCESS_TOKEN=xxxxxxxxxx
THREADS_USER_ID=xxxxxxxxxx

# TikTok API（後で追加）
TIKTOK_CLIENT_KEY=xxxxxxxxxx
TIKTOK_CLIENT_SECRET=xxxxxxxxxx
TIKTOK_ACCESS_TOKEN=xxxxxxxxxx
